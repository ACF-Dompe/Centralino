# =============================================================================
# Cisco Guest Desk — Environment Configuration Template
# =============================================================================
# Copy this file to .env and adjust for your environment.
# For Azure Container Apps deployment, these values are injected via ACA
# environment variables (with Key Vault references for secrets).
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# For local dev with password auth:
#   DATABASE_URL=postgres://user:password@host:5432/dbname
# For ACA with Entra ID Managed Identity (no password):
#   DATABASE_URL=postgres://cgd_app_dev@psql-cgd-dev.postgres.database.azure.com:5432/cgd_dev
DATABASE_URL=postgres://postgres:password@localhost:5432/guest_desk

# ── WLC Defaults ────────────────────────────────────────────────────────────
# WLC_DEFAULT_PASSWORD must be set via Key Vault reference in ACA.
# It is intentionally NOT set here for security.
WLC_DEFAULT_HOST=172.18.106.100
WLC_DEFAULT_PORT=443
WLC_DEFAULT_SSH_PORT=22
WLC_DEFAULT_USERNAME=admin_guest
# WLC_DEFAULT_PASSWORD=   ← set via KV reference in production
WLC_DEFAULT_SSID=Dompe Guest

# WLC HTTP/SSH request timeout (ms)
WLC_HTTP_TIMEOUT_MS=10000
WLC_SSH_TIMEOUT_MS=10000

# WLC SSH host key fingerprint (base64 or hex).
# When set, SSH connections verify the host key against this value.
# MUST be set in production to prevent MITM attacks.
# Example (base64): AAAAB3NzaC1yc2EAAAADAQABAAABAQ...
# WLC_SSH_HOST_KEY=

# WLC TLS verification — must be true in production.
# Set to false only for local dev with self-signed WLC certificates.
# WLC_TLS_REJECT_UNAUTHORIZED=true

# ── SSO SAML 2.0 via Microsoft Entra ID ────────────────────────────────────
# All SAML vars are optional. When SAML_ENTRY_POINT is empty, SSO is disabled
# and the app falls back to WLC-only authentication (useful for local dev).
#
# To enable SSO, register the app in Azure AD (Enterprise Applications):
#   - Identifier (Entity ID): unique URI for this app instance
#   - Reply URL (ACS):      https://<app-fqdn>/api/auth/callback
#   - Logout URL:           https://<app-fqdn>/api/auth/slo/callback
#   - Attributes & Claims:  emailaddress, name, givenname, surname
#
# Download the Federation Metadata XML and extract the values below.
# ────────────────────────────────────────────────────────────────────────────

# The IdP SAML SSO endpoint URL (from Federation Metadata XML → SingleSignOnService)
# Example: https://login.microsoftonline.com/<tenant-id>/saml2
# SAML_ENTRY_POINT=

# Application Entity ID (as configured in Azure AD App Registration)
# SAML_ISSUER=

# Public callback URL where Entra ID POSTs the SAML response
# SAML_CALLBACK_URL=

# Azure AD public certificate (PEM format) for signature verification.
# In ACA, use a Key Vault reference: @Microsoft.KeyVault(...)
# SAML_CERT=

# Private key for decrypting SAML assertions (only if Azure AD is configured
# to encrypt assertions — optional).
# In ACA, use a Key Vault reference: @Microsoft.KeyVault(...)
# SAML_DECRYPTION_KEY=

# SAML nameID format (default: urn:oasis:names:tc:SAML:2.0:nameid-format:persistent)
# SAML_IDENTIFIER_FORMAT=

# IdP Single Logout endpoint URL (from Federation Metadata XML → SingleLogoutService)
# If not set, SLO is disabled (logout destroys only the local session).
# SAML_LOGOUT_URL=

# Where the IdP sends the SAML LogoutResponse after SLO.
# Defaults to SAML_CALLBACK_URL with /callback replaced by /slo/callback.
# SAML_LOGOUT_CALLBACK_URL=

# ── Session ─────────────────────────────────────────────────────────────────
# Secret used to sign session cookies. Must be a long, random string.
# In ACA, use a Key Vault reference: @Microsoft.KeyVault(...)
# SESSION_SECRET=

# ── Azure (ACA deployment) ─────────────────────────────────────────────────
# Application Insights (optional) — set the connection string to enable
# telemetry. In ACA, use a Key Vault reference:
#   @Microsoft.KeyVault(SecretUri=https://kv-cgd-prod.vault.azure.net/secrets/appinsights-connection-string/)
# APPLICATIONINSIGHTS_CONNECTION_STRING=

# Backend internal FQDN for server-side ACA internal calls
# Format: http://ca-{appname}-backend-{env}.{aca-environment-default-domain}
# BACKEND_BASE_URL=

# Azure region (telemetry tag)
# AZURE_REGION=westeurope

# ── Microsoft Graph API Email ────────────────────────────────────────────────
# Platform-provided App Registration with Mail.Send permission.
# When enabled, Graph API is tried first; falls back to SMTP (email_config table).
# In ACA, secrets must use Key Vault references.
# MAIL_GRAPH_ENABLED=true
# MAIL_GRAPH_TENANT_ID=<tenant-id>
# MAIL_GRAPH_CLIENT_ID=<client-id>
# MAIL_GRAPH_CLIENT_SECRET=<client-secret>
# MAIL_GRAPH_USER_ID=<user-object-id-or-upn>  # Mailbox that sends
# MAIL_GRAPH_FROM_ADDRESS=noreply@dompe.com

# ── Database Migration & Seed Controls ────────────────────────────────────
# Guidelines: migrations are a CI pipeline step (not run at app startup).
# Set SKIP_MIGRATIONS=true in production environments deployed via CI.
# SEED_ENABLED defaults to true in non-production, false in production.
# SKIP_MIGRATIONS=true
# SEED_ENABLED=false

# ── Key Vault Reference Quick Reference ─────────────────────────────────────
# Below is the complete list of secrets that must be stored in Key Vault
# and referenced via ACA environment variables. The naming convention is:
#   Key Vault: kv-cgd-{env}  (e.g. kv-cgd-dev, kv-cgd-stg, kv-cgd-prd)
#   Secret name: UPPERCASE_WITH_UNDERSCORES (matches env var name)
#   Reference format:
#     @Microsoft.KeyVault(SecretUri=https://kv-cgd-{env}.vault.azure.net/secrets/{SECRET_NAME}/)
#
# ┌──────────────────────────────────┬──────────┬──────────────────────────────┐
# │ Env var                          │ Required │ Key Vault secret name        │
# ├──────────────────────────────────┼──────────┼──────────────────────────────┤
# │ DATABASE_URL                     │    ✅    │ DATABASE-URL                  │
# │ SESSION_SECRET                   │    ✅    │ SESSION_SECRET               │
# │ WLC_DEFAULT_PASSWORD             │    ✅    │ WLC-DEFAULT-PASSWORD          │
# │ SAML_ENTRY_POINT                 │    ✅    │ SAML-ENTRY-POINT              │
# │ SAML_ISSUER                      │    ✅    │ SAML-ISSUER                   │
# │ SAML_CALLBACK_URL                │    ✅    │ SAML-CALLBACK-URL             │
# │ SAML_CERT                        │    ✅    │ SAML-CERT                     │
# │ SAML_DECRYPTION_KEY              │    🔶    │ SAML-DECRYPTION-KEY           │
# │ SAML_LOGOUT_URL                  │    🔶    │ SAML-LOGOUT-URL               │
# │ SAML_LOGOUT_CALLBACK_URL         │    🔶    │ SAML-LOGOUT-CALLBACK-URL      │
# │ APPLICATIONINSIGHTS_CONNECTION_STRING │ 🔶  │ APPINSIGHTS-CONNECTION-STRING│
# └──────────────────────────────────┴──────────┴──────────────────────────────┘
#
# ✅ = Required in all environments
# 🔶 = Required only if the corresponding feature is enabled
#
# ⚠️  IMPORTANT: After creating/updating a Key Vault reference, the ACA
#    revision must be restarted for changes to take effect.
#
# To set a secret in Key Vault:
#   az keyvault secret set \
#     --vault-name kv-cgd-dev \
#     --name SESSION-SECRET \
#     --value "your-random-secret-here"
#
# The UAMI for each container app must have the 'Key Vault Secrets User' role:
#   az role assignment create \
#     --assignee <uami-principal-id> \
#     --role "Key Vault Secrets User" \
#     --scope /subscriptions/<sub>/resourceGroups/rg-cgd-{env}/providers/Microsoft.KeyVault/vaults/kv-cgd-{env}
